# Público (exposto no bundle client)
NEXT_PUBLIC_WHATSAPP_NUMBER=55000000000
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXX

# Server-only (Meta Conversions API)
# Gerar o token em Events Manager → Settings → Conversions API → Generate access token.
# Enquanto essas duas vars estiverem vazias, o /api/cta aceita o POST e responde
# { ok:true, forwarded:false } sem encaminhar nada — permite desenvolver sem credenciais.
META_CAPI_ACCESS_TOKEN=
META_CAPI_PIXEL_ID=
